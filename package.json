{
  "name": "oh-my-kiro",
  "version": "2.0.0",
  "description": "Multi-agent orchestration for Kiro CLI with native patterns",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "omk": "bin/omk-v2.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "setup": "node bin/omk-v2.js setup",
    "doctor": "node bin/omk-v2.js doctor"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin/",
    "dist/",
    "agents-v2/",
    "prompts-v2/",
    "steering-v2/"
  ],
  "keywords": [
    "kiro",
    "cli",
    "agents",
    "orchestration",
    "multi-agent",
    "subagents",
    "ralph-loop"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
