{
  "name": "oh-my-kiro",
  "version": "0.1.0",
  "description": "Multi-agent orchestration layer for Kiro CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "omk": "bin/omk.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "setup": "node bin/omk.js setup",
    "doctor": "node bin/omk.js doctor"
